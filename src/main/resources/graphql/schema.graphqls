type Query {
    listCustomers(page: Int, perPage: Int): PaginatedCustomers
    getCustomer(id: ID!): Customer
}

type PaginatedCustomers {
    items: [Customer!]!
    totalItems: Int!
    page: Int!
    perPage: Int!
}

type Customer {
    id: ID!
    name: String!
    email: String!
    phoneNumber: String!
    cpf: String!
    active: Boolean!
    createdAt: String!
    updatedAt: String!
    deletedAt: String
}


